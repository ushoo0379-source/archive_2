---
import Homepage from "../components/Homepage.astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

// ✅ 修改 1：这里的名字必须和 config.ts 里的 export 对齐
const collections = ["other_works", "new_media", "animation", "zeitweilig"] as const;

let allImages: { large: string[]; medium: string[]; small: string[] } = {
  large: [],
  medium: [],
  small: [],
};
let allAlts: string[] = [];
let allUrls: string[] = [];

for (const collection of collections) {
  // ✅ 这里的 collection 变量现在会依次取到 animation 等新名字
  const allContent = await getCollection(collection);
  
  const postsWithImages = allContent.filter(
    (post) => post.data.image?.src && post.data.image?.alt,
  );

  const imagePromises = postsWithImages.map(async (post) => {
    const image = post.data.image!;
    const [largeImage, mediumImage, smallImage] = await Promise.all([
      getImage({
        src: image.src,
        alt: image.alt,
        width: 1920,
        height: 1080,
        decoding: "async",
        format: "avif",
        quality: 65,
      }),
      getImage({
        src: image.src,
        alt: image.alt,
        width: 1280,
        height: 720,
        decoding: "async",
        format: "avif",
        quality: 65,
      }),
      getImage({
        src: image.src,
        alt: image.alt,
        width: 854,
        height: 480,
        decoding: "async",
        format: "avif",
        quality: 65,
      }),
    ]);

    return {
      large: largeImage.src,
      medium: mediumImage.src,
      small: smallImage.src,
      alt: image.alt,
      // ✅ 修改 2：确保点击图片跳转到的 URL 也是新路径
      url: `/${collection}/${post.id}`,
    };
  });

  const results = await Promise.all(imagePromises);

  results.forEach((result) => {
    allImages.large.push(result.large);
    allImages.medium.push(result.medium);
    allImages.small.push(result.small);
    allAlts.push(result.alt);
    allUrls.push(result.url);
  });
}

// 🚀 新增：在这里进行随机排序 (Fisher-Yates Shuffle)
// 我们需要同步打乱所有关联数组，确保图片、Alt和URL仍然一一对应
const totalItems = allImages.large.length;
for (let i = totalItems - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  
  // 交换图片路径
  [allImages.large[i], allImages.large[j]] = [allImages.large[j], allImages.large[i]];
  [allImages.medium[i], allImages.medium[j]] = [allImages.medium[j], allImages.medium[i]];
  [allImages.small[i], allImages.small[j]] = [allImages.small[j], allImages.small[i]];
  
  // 交换 Alt 文本
  [allAlts[i], allAlts[j]] = [allAlts[j], allAlts[i]];
  
  // 交换 跳转链接
  [allUrls[i], allUrls[j]] = [allUrls[j], allUrls[i]];
}

const imageSizes = {
  width: {
    large: 1920,
    medium: 1280,
    small: 854,
  },
  height: {
    large: 1080,
    medium: 720,
    small: 480,
  },
};
---

{
  allImages.large.length > 0 ? (
    <Homepage
      title="Home"
      images={JSON.stringify(allImages)}
      alt={JSON.stringify(allAlts)}
      urls={JSON.stringify(allUrls)}
      width={imageSizes.width}
      height={imageSizes.height}
    />
  ) : (
    /* 这里就是你看到报错的地方，只要上面的 collections 对了，这里就会消失 */
    <p>No images found</p>
  )
}