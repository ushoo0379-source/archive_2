---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import { sortByDate } from "../components/sortByDate";

// ✅ 网页顶部显示的标题
const pageTitle = "New Media"; 

// ✅ 抓取 config.ts 中新定义的 new_media 集合
const allPosts = await getCollection("new_media"); 
---

<BaseLayout title={pageTitle} is404Page={false}>
  {
    allPosts
      .sort(sortByDate)
      .map((post) => (
        <BlogPost
          /* ✅ 确保点击后的链接指向新的路由地址 */
          url={`/new_media/${post.id}/`} 
          image={post.data?.image?.src || ""}
          alt={post.data?.image?.alt || ""}
          title={post.data?.title || ""}
          description={post.data?.description || ""}
          pubDate={post.data?.pubDate || ""}
          positionx={post.data?.image?.positionx || ""}
          positiony={post.data?.image?.positiony || ""}
        />
      ))
  }
</BaseLayout>