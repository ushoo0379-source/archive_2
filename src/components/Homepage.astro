---
import BaseLayout from "../layouts/BaseLayout.astro";

export interface Props {
  title: string;
  images: string; 
  alt: string;
  urls: string;
  width: Record<string, number>;
  height: Record<string, number>;
}

const { title, images, alt, urls } = Astro.props;

const parsedImages = JSON.parse(images).small; 
const parsedUrls = JSON.parse(urls);
const parsedAlts = JSON.parse(alt);
---

<BaseLayout title={title} is404Page={false}>
  <section class="showreel-container">
    <div class="video-wrapper">
      <iframe 
        width="100%" 
        style="aspect-ratio: 16/9; margin-bottom: 2rem;" 
        src="https://player.vimeo.com/video/1175406330?autoplay=1&loop=1&autopause=0&muted=1" 
        title="Vimeo video player" 
        frameborder="0" 
        allow="autoplay; fullscreen; picture-in-picture" 
        allowfullscreen>
      </iframe>
      
    </div>
    <div class="showreel-overlay">
      <h1 class="showreel-title">SHOWREEL</h1>
      
    </div>
  </section>

  <div class="grid-wrapper">
    <div class="thumbnail-grid">
      {parsedImages.map((img, index) => (
        <a href={parsedUrls[index]} class="thumb-item group">
          <img src={img} alt={parsedAlts[index]} class="thumb-img" loading="lazy" />
          <div class="thumb-overlay">
            <span class="text-white text-[10px] uppercase tracking-tighter text-center px-1">
              {parsedAlts[index]}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <slot />
</BaseLayout>

<style>
  .showreel-container {
    position: relative;
    width: 100%;
    background: #000;
    overflow: hidden;
    margin-bottom: 2px;
    /* 核心修复：给容器一个基于屏幕宽度的比例高度，确保在不同屏幕下不压扁 */
    height: auto;
    aspect-ratio: 16 / 9;
  }

  .video-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: none;
    /* 消除 YouTube 默认的上下边距偏移 */
    display: block;
  }

  .showreel-overlay {
    position: absolute; 
    inset: 0;
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center;
    background: rgba(0, 0, 0, 0.2); 
    color: white; 
    pointer-events: none;
    z-index: 10;
  }

  .showreel-title { 
    font-size: clamp(1.5rem, 6vw, 4rem);
    font-weight: 800; 
    letter-spacing: -0.05em; 
    margin: 0; 
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  .showreel-subtitle {
    font-size: clamp(0.75rem, 2vw, 1rem);
    font-family: monospace;
    letter-spacing: 0.2em;
    opacity: 0.8;
  }

  /* 下方网格逻辑 */
  .grid-wrapper {
    width: 100%;
    padding: 0 2px;
  }

  .thumbnail-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  @media (min-width: 1024px) {
    .thumbnail-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .thumb-item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .thumb-item:hover .thumb-overlay {
    opacity: 1;
  }
</style>