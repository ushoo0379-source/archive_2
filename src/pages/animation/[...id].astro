---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";

export async function getStaticPaths() {
  const posts = await getCollection("animation");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const date = new Date(post.data.pubDate);
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    crossorigin="anonymous"
  />

  <div class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-12 border-b border-gray-200 dark:border-gray-800 pb-8">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4 font-overpass-mono">
        {post.data.title}
      </h1>
      <div class="flex items-center text-sm text-gray-500 dark:text-gray-400 space-x-4">
        <time datetime={post.data.pubDate.toString()}>{formattedDate}</time>
        {post.data.author && <span>· {post.data.author}</span>}
      </div>
    </header>

    {post.data.image && post.data.image.src && (
      <div class="mb-12 aspect-video bg-gray-100 dark:bg-gray-900">
        <img
          src={post.data.image.src}
          alt={post.data.image.alt || post.data.title}
          class="w-full h-full object-cover"
          style={{
            objectPosition: `${post.data.image.positionx || '50%'} ${post.data.image.positiony || '50%'}`
          }}
        />
      </div>
    )}

    <Prose>
      <div class="animation-content">
        <Content />
      </div>
    </Prose>

    {post.data.tags && post.data.tags.length > 0 && (
      <footer class="mt-16 pt-8 border-t border-gray-100 dark:border-gray-800">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="text-gray-600 dark:text-gray-400 text-xs font-medium">
              #{tag}
            </span>
          ))}
        </div>
      </footer>
    )}
  </div>
</BaseLayout>

<style is:global>
  /* 仅保留基础排版，不添加装饰性样式 */
  .animation-content img {
    max-width: 100%;
    height: auto;
    margin: 2rem 0;
  }

  .animation-content p {
    margin-bottom: 1.5rem;
    line-height: 1.75;
  }
</style>